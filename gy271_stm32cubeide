HAL_StatusTypeDef QMC5883_Init(void)
{
    uint8_t data;

    /* Soft Reset */
    data = 0x01;
    if(HAL_I2C_Mem_Write(&hi2c1,
                         QMC5883_ADDR,
                         QMC5883_REG_RESET,
                         I2C_MEMADD_SIZE_8BIT,
                         &data,
                         1,
                         HAL_MAX_DELAY) != HAL_OK)
    {
        return HAL_ERROR;
    }

    HAL_Delay(10);

    /*
     * Control Register 1 (0x09)
     * OSR = 512
     * RNG = ±8G
     * ODR = 200Hz
     * MODE = Continuous
     *
     * Giá trị = 0x1D
     */
    data = 0x1D;

    if(HAL_I2C_Mem_Write(&hi2c1,
                         QMC5883_ADDR,
                         QMC5883_REG_CONTROL1,
                         I2C_MEMADD_SIZE_8BIT,
                         &data,
                         1,
                         HAL_MAX_DELAY) != HAL_OK)
    {
        return HAL_ERROR;
    }

    HAL_Delay(10);

    return HAL_OK;
}

HAL_StatusTypeDef QMC5883_ReadRaw(void)
{
    if(HAL_I2C_Mem_Read(&hi2c1,
                        QMC5883_ADDR,
                        QMC5883_REG_X_LSB,
                        I2C_MEMADD_SIZE_8BIT,
                        qmc_buffer,
                        6,
                        HAL_MAX_DELAY) != HAL_OK)
    {
        return HAL_ERROR;
    }

    qmc_x = (int16_t)((qmc_buffer[1] << 8) | qmc_buffer[0]);
    qmc_y = (int16_t)((qmc_buffer[3] << 8) | qmc_buffer[2]);
    qmc_z = (int16_t)((qmc_buffer[5] << 8) | qmc_buffer[4]);

    return HAL_OK;
}

float QMC5883_GetHeading(void)
{
    float heading;

    heading = atan2f((float)qmc_y, (float)qmc_x);
    heading = heading * 180.0f / 3.14159265f;

    if(heading < 0)
    {
        heading += 360.0f;
    }

    return heading;
}


